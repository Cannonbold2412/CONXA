{
  "name": "conxa-build-studio",
  "version": "0.1.0",
  "description": "Conxa Build Studio — record, compile, and ship automation plugins",
  "main": "main.js",
  "author": "Conxa",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "node scripts/cleanup-dev.js && concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "node scripts/dev-electron.js",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:renderer && electron-builder --config electron-builder.yml",
    "test:bridge": "node test/bridge.test.js"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.3.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "radix-ui": "^1.4.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^6.0.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.0",
    "zustand": "^5.0.0"
  }
}
