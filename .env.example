# Copy this file to .env and fill in the values below.
# Variables not listed here have sensible defaults in conxa_core/config.py — override only if needed.

# ============================================================================
# Multi-Provider LLM Key Pool (free-tier rotation)
# ============================================================================
# Compile-time LLM use is heavy: ~5 selector calls + 4 vision verifications per
# step. To avoid rate limits, configure several providers and pool keys from
# multiple free-tier accounts (e.g. one key per Gmail account on Groq, Google
# AI Studio, NVIDIA NIM, etc.).
#
# Each provider:
#   *_API_KEYS — comma-separated keys (one per Gmail/account)
#   *_TEXT_MODEL / *_VISION_MODEL — leave blank to use the default model
#   *_ENABLED=true — include this provider in the rotation pool
#
# The router:
#   - builds a flat pool of (provider, key, model) tuples across all enabled
#     providers, sorted by remaining budget
#   - on 429 / rate-limit: cools the offending key for LLM_ROUTER_COOLDOWN_SECS
#     and tries the next entry
#   - on 401 / 403: removes the key from the pool for the rest of the process
#   - vision calls only route to providers with a *_VISION_MODEL set

# --- Groq (fastest free-tier inference; 300+ tok/s on Llama 3.3 70B) ---
# Sign up: https://console.groq.com/keys  (no credit card)
# Free tier: 30 req/min, 30k tok/min, 14,400 req/day per key
# Llama 4 Scout supports vision; Llama 3.3/4 Maverick are text-only
GROQ_ENABLED=true
GROQ_ENDPOINT=https://api.groq.com/openai/v1
GROQ_API_KEYS=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Google AI Studio / Gemini (best free-tier vision) ---
# Sign up: https://aistudio.google.com/apikey  (no credit card)
# Free tier: 1,500 req/day on Flash models. Pro models are paid as of Apr 2026.
# Use OpenAI-compatibility layer; all Flash models are natively multimodal
GOOGLE_AI_STUDIO_ENABLED=true
GOOGLE_AI_STUDIO_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_AI_STUDIO_API_KEYS=
GOOGLE_AI_STUDIO_TEXT_MODEL=gemini-2.5-flash
GOOGLE_AI_STUDIO_VISION_MODEL=gemini-2.5-flash

# --- NVIDIA NIM (text + vision, 100+ free models) ---
# Sign up: https://build.nvidia.com/settings/api-keys  (no credit card)
# Free tier: 5,000 credits + 40 req/min per model per account. API keys prefixed nvapi-
NVIDIA_NIM_ENABLED=true
NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEYS=
NVIDIA_NIM_TEXT_MODEL=meta/llama-4-maverick-17b-128e-instruct
NVIDIA_NIM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# --- Cerebras (very fast text, 2,600+ tok/s on wafer-scale silicon) ---
# Sign up: https://cloud.cerebras.ai  (no credit card)
# Free tier: 1M tokens/day, 30 req/min, 8K context cap
# Text only; no vision models on Cerebras
CEREBRAS_ENABLED=false
CEREBRAS_ENDPOINT=https://api.cerebras.ai/v1
CEREBRAS_API_KEYS=
CEREBRAS_TEXT_MODEL=llama-4-scout-17b-16e-instruct
CEREBRAS_VISION_MODEL=

# --- Together AI (80+ free models including Llama 4 vision) ---
# Sign up: https://api.together.ai  ($5 trial credits, then paid)
# Free serverless models exist but are rate-limited
TOGETHER_ENABLED=false
TOGETHER_ENDPOINT=https://api.together.xyz/v1
TOGETHER_API_KEYS=
TOGETHER_TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
TOGETHER_VISION_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# --- OpenRouter (aggregator; models with :free suffix are free) ---
# Sign up: https://openrouter.ai/keys  (no credit card)
# Free tier: 50 req/day without account balance, 20 req/min
OPENROUTER_ENABLED=false
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_API_KEYS=
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v3:free
OPENROUTER_VISION_MODEL=meta-llama/llama-4-scout:free

# --- Mistral La Plateforme (text + Pixtral vision) ---
# Sign up: https://console.mistral.ai/api-keys  (no credit card on free tier)
# Free experimentation tier with daily token quotas
MISTRAL_ENABLED=false
MISTRAL_ENDPOINT=https://api.mistral.ai/v1
MISTRAL_API_KEYS=
MISTRAL_TEXT_MODEL=mistral-large-latest
MISTRAL_VISION_MODEL=pixtral-large-latest

# --- Router behavior ---
LLM_ROUTER_COOLDOWN_SECS=60               # how long to cool a key after 429
LLM_ROUTER_MAX_RETRIES=3                  # retries before giving up on a request
LLM_ROUTER_REQUEST_TIMEOUT_MS=30000       # per-request timeout
LLM_ROUTER_PREFER_FAST_FOR_TEXT=true      # prefer Groq/Cerebras for text-only calls when available

# ============================================================================
# Dependency Manifest (served by /api/v1/updates/deps-manifest)
# All deps are independently versioned — update these without releasing a new
# Build Studio version. Set on Render; leave SHA256 fields blank until CI
# computes them from the published release assets.
# ============================================================================

# GitHub repo that hosts release artifacts (runtime, studio installer)
CONXA_GITHUB_REPO=Cannonbold2412/CONXA

# ── NSIS (Windows installer compiler) ──────────────────────────────────────
CONXA_NSIS_VERSION=3.10
CONXA_NSIS_URL=https://downloads.sourceforge.net/project/nsis/NSIS%203/3.10/nsis-3.10.zip
CONXA_NSIS_SHA256=

# ── MCP Runtime — host layer (conxa-runtime.exe, ~85 MB, quarterly) ────────
# CI posts these after each host-v* tag build.
CONXA_HOST_VERSION=host-v1.0.0
CONXA_HOST_WIN_URL=https://github.com/Cannonbold2412/CONXA/releases/download/host-v1.0.0/conxa-runtime.exe
CONXA_HOST_WIN_SHA256=
CONXA_KEYTAR_WIN_URL=https://github.com/Cannonbold2412/CONXA/releases/download/host-v1.0.0/keytar.node
CONXA_KEYTAR_WIN_SHA256=

# ── MCP Runtime — app layer (~60 KB zip, every code release) ─────────────────
# CI posts these after each app-v* tag build.
CONXA_APP_VERSION=app-v1.0.0
CONXA_APP_MIN_HOST=host-v1.0.0
CONXA_APP_BUNDLE_URL=
CONXA_APP_BUNDLE_SHA256=

# ── Cloud admin token (used by CI to POST updated manifests after each build) ─
CONXA_ADMIN_TOKEN=

# ── Playwright / Chromium — informational only ─────────────────────────────
# Baked into the PyInstaller bundle; cannot update without a new Build Studio
# release. Exposed here so the runtime-manifest endpoint can tell the runtime
# which Chromium revision to install.
CONXA_PLAYWRIGHT_VERSION=1.59.0
CONXA_CHROMIUM_REVISION=1227

# ── Build Studio installer manifest ────────────────────────────────────────
# Served by /api/v1/updates/studio-manifest and /updates/studio/latest.yml.
# Only CONXA_STUDIO_VERSION is required — the win URL and latest.yml URL are
# derived from it automatically. Set the override vars only when hosting
# artifacts outside GitHub Releases.
CONXA_STUDIO_VERSION=studio-v1.0.0
# CONXA_STUDIO_WIN_SHA256=
# CONXA_STUDIO_WIN_URL=         # override only if not on GitHub Releases
# CONXA_STUDIO_LATEST_YML_URL=  # override only if not on GitHub Releases

# ── Runtime CDN base (used by installer_builder.py when staging runtime) ───
CONXA_RUNTIME_CDN_URL=https://github.com/Cannonbold2412/CONXA/releases/download

# ── Build Studio → Cloud API base URL ──────────────────────────────────────
# bootstrap.py fetches the deps-manifest from this host on every startup.
CONXA_CLOUD_API=https://apis.conxa.in

# ── Client-side manifest cache TTL (seconds, default 86400 = 24 h) ─────────
CONXA_DEPS_MANIFEST_TTL_SECONDS=86400

# ============================================================================
# Auth + Production
# ============================================================================

# Build Studio Electron app — Clerk OAuth credentials.
# CONXA_CLERK_CLIENT_SECRET must be set in the shell (or CI env) before `npm run dev`
# or `npm run build`. It is never committed to source code.
# Obtain from: Clerk Dashboard → Applications → <app> → OAuth Applications.
CONXA_CLERK_DOMAIN=https://clerk.conxa.in
CONXA_CLERK_CLIENT_ID=Z7O8UdIVowd3Aegx
CONXA_CLERK_CLIENT_SECRET=

# Cloud backend — Clerk auth. Set SKILL_AUTH_REQUIRED=true outside local/dev.
# Issuer = Frontend API URL from Clerk (e.g. https://<instance>.clerk.accounts.dev).
# JWKS URL = same host + /.well-known/jwks.json
SKILL_AUTH_REQUIRED=false
SKILL_CLERK_ISSUER=
SKILL_CLERK_JWKS_URL=
SKILL_CLERK_AUTHORIZED_PARTIES=
SKILL_CLERK_AUDIENCE=
# Clerk Backend API secret (sk_...). Required for admin-gated actions (e.g. publish)
# from Build Studio: its OAuth access token carries org_id but not org_role, so the
# backend resolves the caller's org role via the Clerk Backend API. Without this,
# org members are treated as non-admins and publish returns 403 "admin role required".
CLERK_SECRET_KEY=
# Shared secret used only between the Next.js API proxy and the cloud backend.
# Set the same high-entropy value as CONXA_API_PROXY_SECRET in the Vercel frontend env.
# Without this, the backend cannot resolve the active Clerk org from proxy headers and
# falls back to JWT claims — org-scoped features (skill packs, billing) may misbehave.
SKILL_API_PROXY_SHARED_SECRET=

# Production backing services
SKILL_DATABASE_URL=
SKILL_REDIS_URL=
SKILL_BLOB_READ_WRITE_TOKEN=

# Public API base URL embedded in pack.json (sync + telemetry endpoints).
# Must be set in production (SKILL_AUTH_REQUIRED=true) to prevent X-Forwarded-Host injection.
# Example: https://api.conxa.in
SKILL_API_BASE_URL=

# Razorpay billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Optional legacy frontend fallback. Current checkout uses the backend-returned key_id.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Pre-create these monthly INR plans in Razorpay Dashboard/API before production deploy.
# Starter: ₹29,999/month. Pro: ₹79,999/month.
RAZORPAY_STARTER_PLAN_ID=
RAZORPAY_PRO_PLAN_ID=
